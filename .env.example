COMPOSE_PROJECT_NAME=vparkbb
TZ=UTC
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Domain/cert settings used in README commands.
APP_DOMAIN=www.victoriapark.io
APP_DOMAIN_ALT=victoriapark.io
LETSENCRYPT_EMAIL=ops@victoriapark.io
# Local dev example: http://localhost:8088
VPARK_PORTAL_URL=https://victoriapark.io
# Set explicit origin for cross-site cookie validation (optional).
# Example: https://www.victoriapark.io or http://localhost:8088
VPARK_SSO_ALLOWED_ORIGIN=
VPARK_SUMMARY_BUTTON_ENABLED=1

# MariaDB settings.
DB_NAME=phpbb
DB_USER=phpbb
DB_PASSWORD=replace_with_strong_password
DB_ROOT_PASSWORD=replace_with_strong_root_password

# Backup settings.
BACKUP_DIR=./backups/db
BACKUP_RETENTION_DAYS=14
