# Runtime / generated data
# -------------------------------
cache/*
!cache/.htaccess
!cache/index.htm

files/*
!files/.htaccess
!files/index.htm

store/*
!store/.htaccess
!store/index.htm

# phpBB downloads/temp artifacts
download/*
!download/.htaccess
!download/index.htm

